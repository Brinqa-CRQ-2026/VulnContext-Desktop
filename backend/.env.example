# Runtime database connection for local backend testing against Supabase.
# Use a real Postgres/Supabase connection string here, not the project HTTPS URL.
# SQLAlchemy should use a DSN that starts with `postgresql://`.
#
# Example:
# SUPABASE_DB_URL=postgresql://postgres:<DB_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
#
# If your environment does not support IPv6 or you prefer pooled connections, copy the
# Session pooler string from the Supabase dashboard Connect panel and change the prefix
# to `postgresql://` if it is shown as `postgres://`.


# Optional alternate names also recognized by the backend, but `SUPABASE_DB_URL`
# is the preferred setting for this project.
# POSTGRES_DATABASE_URL=
# DATABASE_URL=

# NVD bulk feed cache settings
NVD_FEED_BASE_URL=https://nvd.nist.gov/feeds/json/cve/2.0
NVD_TIMEOUT_SEC=30
NVD_FEED_START_YEAR=2002
NVD_FEED_DATA_DIR=backend/data/nvd

# Optional KEV enrichment input for the next step
KEV_CSV_PATH=backend/data/cisa_kev.csv
